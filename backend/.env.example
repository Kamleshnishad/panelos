# ============================================================
# PanelOS Environment Configuration
# ============================================================
# Copy this file to .env and update values for your environment
# ============================================================

# Application Settings
APP_NAME="PanelOS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=panelos_dev
DB_USERNAME=panelos_user
DB_PASSWORD=panelos_secret

# Redis Configuration
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=redis_secret
REDIS_PORT=6379

# Caching
CACHE_STORE=redis

# Queue
QUEUE_CONNECTION=redis

# Session
SESSION_DRIVER=cookie

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:5173
SANCTUM_GUARD=api

# Mail
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="PanelOS"

# Stripe Payment Gateway
STRIPE_PUBLIC_KEY=pk_test_your_public_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_test_your_webhook_secret_here

# Twilio SMS Service
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_FROM_NUMBER=+1234567890

# Frontend
FRONTEND_URL=http://localhost:5173

MYSQLDUMP_PATH=

# e-Invoice GSP (set when you have a GSP contract)
EINVOICE_GSP_ENABLED=false
EINVOICE_GSP_URL=
EINVOICE_GSP_EWAY_URL=
EINVOICE_GSP_CLIENT_ID=
EINVOICE_GSP_CLIENT_SECRET=
EINVOICE_GSP_GSTIN=
EINVOICE_GSP_USERNAME=
EINVOICE_GSP_PASSWORD=
