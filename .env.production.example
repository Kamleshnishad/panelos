# ═══════════════════════════════════════════════════════════════
#  PanelOS Production Environment — TEMPLATE
#  Copy this to .env.production on the server (NOT in git!) and fill in
#  the real values. Compose reads it via --env-file at deploy time.
# ═══════════════════════════════════════════════════════════════

# ── Image version (which build of PanelOS we run) ──────────────
# `latest` is fine for manual deploys. CI/CD will inject the git SHA
# (e.g. `abc1234`) so we can roll back by deploying a previous tag.
PANELOS_VERSION=latest

# ── Application ────────────────────────────────────────────────
APP_NAME=PanelOS
APP_ENV=production
# Generate once with: docker run --rm php:8.3-cli-alpine sh -c "php -r 'echo \"base64:\" . base64_encode(random_bytes(32)) . PHP_EOL;'"
# OR reuse the APP_KEY from your local backend/.env
APP_KEY=
APP_DEBUG=false
APP_URL=http://208.87.135.37:3030
FRONTEND_URL=http://208.87.135.37:3030
LOG_CHANNEL=stack
LOG_LEVEL=info

# ── Database (panelos DB on the HOST MySQL, reached via gateway) ─
# DB_HOST is overridden to `host.docker.internal` by compose itself —
# the value here is just documentation.
DB_CONNECTION=mysql
DB_HOST=host.docker.internal
DB_PORT=3306
DB_DATABASE=panelos
DB_USERNAME=panelos_app
# From /root/.panelos_db_password on the server. Paste it here.
DB_PASSWORD=

# ── Caching / Queue / Session (no Redis — file-based) ──────────
CACHE_STORE=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=cookie

# ── Sanctum (CSRF / stateful domains) ──────────────────────────
SANCTUM_STATEFUL_DOMAINS=208.87.135.37:3030
SANCTUM_GUARD=api

# ── Mail (log driver = writes mail to laravel.log; switch to smtp later) ─
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@panelos.local
MAIL_FROM_NAME="PanelOS"

# ── Payment gateways (Stripe + Razorpay) ───────────────────────
# These are runtime-loaded from the DB per your design — only set here if
# any backend code reads them via env() (most production keys still live
# in the DB-side platform_settings table for multi-tenant flexibility).
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_ENABLED=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Twilio (SMS / WhatsApp — disabled by default) ──────────────
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── e-Invoice GSP (only if you have a real GSP contract) ───────
EINVOICE_GSP_ENABLED=false

# ── Platform (PanelOS seller) GST identity ─────────────────────
PLATFORM_NAME="PanelOS Technologies"
PLATFORM_GSTIN=
PLATFORM_PAN=
PLATFORM_STATE=Gujarat
PLATFORM_STATE_CODE=24
PLATFORM_EMAIL=billing@panelos.app
