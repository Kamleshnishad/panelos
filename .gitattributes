# Normalize all text files to LF in the repo; check out native on each OS.
* text=auto eol=lf

# Windows scripts must stay CRLF to run correctly.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Treat these as binary (never line-ending converted, never diffed as text).
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.zip   binary
